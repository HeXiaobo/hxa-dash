{
  "name": "hxa-dash",
  "version": "0.1.0",
  "description": "HxA Dash — Agent Team Information Panel",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run",
    "sync:activity-reporter": "cp scripts/activity-reporter.mjs public/scripts/activity-reporter.mjs && cp scripts/activity-reporter-openclaw.mjs public/scripts/activity-reporter-openclaw.mjs",
    "check:activity-reporter": "cmp -s scripts/activity-reporter.mjs public/scripts/activity-reporter.mjs && cmp -s scripts/activity-reporter-openclaw.mjs public/scripts/activity-reporter-openclaw.mjs",
    "sync:health-reporter": "cp scripts/health-reporter.mjs public/scripts/health-reporter.mjs",
    "check:health-reporter": "cmp -s scripts/health-reporter.mjs public/scripts/health-reporter.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
