# ============================================
# hxa-dash Environment Configuration
# ============================================

# Node environment
NODE_ENV=development

# Server port
PORT=3479

# ============================================
# Feishu OAuth Configuration
# ============================================

# Feishu bot app credentials (get from Feishu Admin Console)
# App ID: cli_a940cff668b81bde (Mylos bot)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# Zhiwai's tenant key (for access control - only allow Zhiwai employees)
# This is the tenant_key returned from Feishu OAuth
FEISHU_TENANT_KEY=your_zhiwai_tenant_key

# ============================================
# JWT Authentication
# ============================================

# Secret key for signing JWT tokens (use a random 32+ character string)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_change_in_production

# ============================================
# GitLab & Connect Configuration
# ============================================

# See config/sources.example.json for data source configuration
